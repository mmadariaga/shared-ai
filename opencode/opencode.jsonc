{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": {
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.aws/**": "deny",
      "~/.azure/**": "deny",
      "~/.kube/**": "deny",
      "~/.docker/**": "deny",
      "~/.config/gcloud/**": "deny",
      ".env*": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*.p12": "deny",
      "*.jks": "deny",
      "*credentials*": "deny"
    },
  },
  "agent": {
    "explore": {
      "mode": "subagent",
      // Put your trusted low-cost model here
      "model": "opencode-go/deepseek-v4-flash"
    }
  }
}
